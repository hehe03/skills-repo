{
  "rules": [
    {
      "id": "parse_error",
      "layer": "general",
      "label": "badcase",
      "weight": 1.0,
      "group": "hard_failure",
      "group_cap": 1.0,
      "description": "Trace JSON could not be parsed.",
      "all": [{"feature": "parse_error", "op": "==", "value": true}]
    },
    {
      "id": "empty_trace",
      "layer": "general",
      "label": "badcase",
      "weight": 0.9,
      "group": "hard_failure",
      "group_cap": 1.0,
      "description": "Trace object is empty.",
      "all": [{"feature": "is_empty_trace", "op": "==", "value": true}]
    },
    {
      "id": "no_observable_steps",
      "layer": "general",
      "label": "badcase",
      "weight": 0.45,
      "group": "structure_missing",
      "group_cap": 0.55,
      "description": "Trace has no observable steps, messages, actions, or tool events.",
      "all": [{"feature": "has_steps", "op": "==", "value": false}]
    },
    {
      "id": "tool_or_runtime_error",
      "layer": "general",
      "label": "badcase",
      "weight": 0.7,
      "group": "error_signal",
      "group_cap": 0.75,
      "description": "Trace contains error, exception, timeout, or failure text.",
      "all": [{"feature": "has_error_text", "op": "==", "value": true}]
    },
    {
      "id": "missing_final_answer_strong",
      "layer": "general",
      "label": "badcase",
      "weight": 1,
      "group": "result_missing",
      "group_cap": 1,
      "description": "User-configured final answer field is enabled, but this trace does not expose a non-empty final answer.",
      "all": [
        {"feature": "final_answer_evidence_enabled", "op": "==", "value": true},
        {"feature": "final_answer_evidence_strength", "op": "==", "value": "strong"},
        {"feature": "has_final_answer", "op": "==", "value": false}
      ]
    },
    {
      "id": "missing_final_answer_medium",
      "layer": "general",
      "label": "badcase",
      "weight": 0.35,
      "group": "result_missing",
      "group_cap": 0.6,
      "description": "Default or LLM-discovered final answer field is enabled, but this trace does not expose a non-empty final answer.",
      "all": [
        {"feature": "final_answer_evidence_enabled", "op": "==", "value": true},
        {"feature": "final_answer_evidence_strength", "op": "==", "value": "medium"},
        {"feature": "has_final_answer", "op": "==", "value": false}
      ]
    },
    {
      "id": "high_empty_result_ratio",
      "layer": "general",
      "label": "badcase",
      "weight": 0.35,
      "group": "result_missing",
      "group_cap": 0.6,
      "description": "Most observed steps have empty results.",
      "all": [
        {"feature": "step_count", "op": ">=", "value": 3},
        {"feature": "empty_result_ratio", "op": ">=", "value": 0.7}
      ]
    },
    {
      "id": "repeated_action_loop",
      "layer": "general",
      "label": "badcase",
      "weight": 0.45,
      "group": "loop_or_inefficiency",
      "group_cap": 0.55,
      "description": "Same action repeats consecutively, suggesting a loop or stuck agent.",
      "all": [{"feature": "max_consecutive_same_action", "op": ">=", "value": 3}]
    },
    {
      "id": "excessive_step_count",
      "layer": "general",
      "label": "badcase",
      "weight": 0.25,
      "group": "loop_or_inefficiency",
      "group_cap": 0.55,
      "description": "Trace has many steps, which is a weak risk signal for inefficient or stuck execution.",
      "all": [{"feature": "step_count", "op": ">=", "value": 25}]
    },
    {
      "id": "has_final_answer_strong",
      "layer": "general",
      "label": "goodcase",
      "weight": 1,
      "group": "completion_evidence",
      "group_cap": 1,
      "description": "Trace contains a non-empty user-configured final answer field.",
      "all": [
        {"feature": "final_answer_evidence_enabled", "op": "==", "value": true},
        {"feature": "final_answer_evidence_strength", "op": "==", "value": "strong"},
        {"feature": "has_final_answer", "op": "==", "value": true}
      ]
    },
    {
      "id": "has_final_answer_medium",
      "layer": "general",
      "label": "goodcase",
      "weight": 0.3,
      "group": "completion_evidence",
      "group_cap": 0.45,
      "description": "Trace contains a non-empty default or LLM-discovered final answer field.",
      "all": [
        {"feature": "final_answer_evidence_enabled", "op": "==", "value": true},
        {"feature": "final_answer_evidence_strength", "op": "==", "value": "medium"},
        {"feature": "has_final_answer", "op": "==", "value": true}
      ]
    },
    {
      "id": "high_nonempty_result_ratio",
      "layer": "general",
      "label": "goodcase",
      "weight": 0.25,
      "group": "result_evidence",
      "group_cap": 0.3,
      "description": "Most observed steps have non-empty results.",
      "all": [
        {"feature": "step_count", "op": ">=", "value": 1},
        {"feature": "nonempty_result_ratio", "op": ">=", "value": 0.7}
      ]
    },
    {
      "id": "no_errors_or_loops",
      "layer": "general",
      "label": "goodcase",
      "weight": 0.25,
      "group": "clean_execution",
      "group_cap": 0.25,
      "description": "Trace has no error text and no repeated-action loop signal.",
      "all": [
        {"feature": "has_error_text", "op": "==", "value": false},
        {"feature": "max_consecutive_same_action", "op": "<", "value": 3}
      ]
    }
  ]
}
